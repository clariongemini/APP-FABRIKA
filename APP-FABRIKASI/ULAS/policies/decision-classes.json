{
  "version": "2.0",
  "description": "Not all decisions weigh the same. Executable classification.",
  "classes": {
    "A": {
      "label": "documentation",
      "label_tr": "Dokümantasyon",
      "risk": "low",
      "tier": 1,
      "min_reviews": 1,
      "required_capabilities": ["planner"],
      "examples": ["README update", "PURPOSE.md", "ADR draft"]
    },
    "B": {
      "label": "refactor",
      "label_tr": "Refactor",
      "risk": "medium",
      "tier": 2,
      "min_reviews": 2,
      "required_capabilities": ["architect", "qa"],
      "examples": ["Module rename", "Test fix", "Non-breaking API change"]
    },
    "C": {
      "label": "architecture",
      "label_tr": "Mimari değişiklik",
      "risk": "high",
      "tier": 3,
      "min_reviews": 3,
      "required_capabilities": ["architect", "security", "auditor"],
      "examples": ["New module", "Data layer change", "Auth model change"]
    },
    "D": {
      "label": "release",
      "label_tr": "Release etkileyen",
      "risk": "critical",
      "tier": "critical",
      "min_reviews": 3,
      "full_review": true,
      "required_capabilities": ["qa", "auditor", "security"],
      "founder_approval": true,
      "examples": ["Play Store ship", "Monetization change", "Security exception"]
    }
  },
  "default_class": "B"
}
