{
  "version": "2.0",
  "description": "Risk → context tier → review depth. Executable policy.",
  "tiers": {
    "1": {
      "name": "minimal",
      "token_budget_hint": 2000,
      "risk_levels": ["low"],
      "context_load": ["venture_charter_summary", "relevant_purpose_md"]
    },
    "2": {
      "name": "standard",
      "token_budget_hint": 8000,
      "risk_levels": ["medium"],
      "context_load": ["venture_charter", "platform_adapter", "never_again_index", "compressed_adr"]
    },
    "3": {
      "name": "deep",
      "token_budget_hint": 20000,
      "risk_levels": ["high"],
      "context_load": ["venture_charter", "platform_adapter", "never_again_full", "proven_patterns", "evidence_summary"]
    },
    "critical": {
      "name": "full_review",
      "token_budget_hint": 25000,
      "risk_levels": ["critical"],
      "full_review": true,
      "context_load": ["venture_charter", "platform_adapter", "never_again_full", "proven_patterns", "evidence_summary", "review_matrix", "trust_scores"]
    }
  },
  "escalation_rules": [
    {"if": "decision_class", "equals": "A", "tier": 1},
    {"if": "decision_class", "equals": "B", "tier": 2},
    {"if": "decision_class", "equals": "C", "tier": 3},
    {"if": "decision_class", "equals": "D", "tier": "critical"},
    {"if": "never_again_conflict", "equals": true, "escalate_to": "critical"},
    {"if": "confidence_below", "value": 0.4, "escalate_one_tier": true}
  ]
}
