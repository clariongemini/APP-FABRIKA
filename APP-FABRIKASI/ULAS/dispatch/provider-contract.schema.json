{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Provider Dispatch Contract",
  "description": "Stable envelope for all providers. Swap provider_id without changing consumers.",
  "type": "object",
  "required": ["contract_version", "dispatch_id", "capability_id", "provider_id", "invoke", "status"],
  "properties": {
    "contract_version": { "const": "1.0" },
    "dispatch_id": { "type": "string" },
    "decision_id": { "type": "string" },
    "work_package_id": { "type": "string" },
    "capability_id": { "type": "string" },
    "provider_id": { "type": "string" },
    "provider_type": { "enum": ["manual", "local_shell", "ai_ide", "ai_api"] },
    "invoke": {
      "type": "object",
      "required": ["schema"],
      "properties": {
        "schema": { "enum": ["shell_invoke", "ai_invoke", "manual_invoke"] },
        "cwd": { "type": "string" },
        "cmd": { "type": "string" },
        "timeout_sec": { "type": "integer" },
        "context_refs": { "type": "array", "items": { "type": "string" } },
        "instruction": { "type": "string" },
        "acceptance": { "type": "string" },
        "constraints": { "type": "array", "items": { "type": "string" } }
      }
    },
    "status": { "enum": ["pending", "dispatched", "completed", "skipped", "failed"] },
    "result": {
      "type": "object",
      "properties": {
        "success": { "type": "boolean" },
        "exit_code": { "type": "integer" },
        "stdout_ref": { "type": "string" },
        "skipped": { "type": "boolean" },
        "reason": { "type": "string" },
        "completed_at": { "type": "string", "format": "date-time" }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
