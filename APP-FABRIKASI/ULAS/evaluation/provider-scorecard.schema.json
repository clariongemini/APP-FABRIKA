{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Provider Scorecard",
  "description": "Comparison record for same capability across providers. Populated by evidence — not synthetic scores.",
  "type": "object",
  "required": ["capability_id", "comparisons"],
  "properties": {
    "capability_id": { "type": "string" },
    "venture_slug": { "type": "string" },
    "decision_id": { "type": "string" },
    "methodology_ref": { "type": "string" },
    "comparisons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["provider_id"],
        "properties": {
          "provider_id": { "type": "string" },
          "run_id": { "type": "string" },
          "dimensions": {
            "type": "object",
            "properties": {
              "verification_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
              "retry_count": { "type": "integer" },
              "time_to_evidence_sec": { "type": "number" },
              "human_intervention_count": { "type": "integer" },
              "outcome": { "enum": ["approved_success", "approved_failed", "inconclusive", "not_run"] }
            }
          },
          "evidence_refs": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" }
        }
      }
    },
    "recorded_at": { "type": "string", "format": "date-time" }
  }
}
