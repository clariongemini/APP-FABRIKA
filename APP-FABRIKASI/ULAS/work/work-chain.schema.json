{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ULAS Work Chain",
  "type": "object",
  "required": ["work_id", "decision_id", "venture_slug", "work_packages", "execution_manifest", "verification_manifest", "evidence_manifest", "state"],
  "properties": {
    "work_id": { "type": "string" },
    "decision_id": { "type": "string" },
    "venture_slug": { "type": "string" },
    "generated_at": { "type": "string" },
    "codebase_path": { "type": "string" },
    "platform": { "type": "string" },
    "state": { "enum": ["ready", "executing", "verified", "closed", "blocked"] },
    "work_packages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "sequence", "capability", "task", "status"],
        "properties": {
          "id": { "type": "string" },
          "sequence": { "type": "integer" },
          "capability": { "type": "string" },
          "platform": { "type": "string" },
          "task": { "type": "string" },
          "status": { "enum": ["pending", "in_progress", "done", "failed", "skipped"] },
          "acceptance": { "type": "string" },
          "retry_of": { "type": "string" }
        }
      }
    },
    "execution_manifest": { "type": "object" },
    "verification_manifest": { "type": "object" },
    "evidence_manifest": { "type": "object" }
  }
}
