{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Capability Knowledge Store",
  "description": "Per-capability operational memory. Not venture-scoped lessons — capability-scoped knowledge.",
  "type": "object",
  "required": ["capability_id", "version", "entries"],
  "properties": {
    "capability_id": { "type": "string", "pattern": "^[a-z]+\\.[a-z_]+$" },
    "label": { "type": "string" },
    "version": { "type": "string" },
    "updated_at": { "type": "string", "format": "date-time" },
    "stats": {
      "type": "object",
      "properties": {
        "ventures_contributed": { "type": "integer" },
        "entries_proven": { "type": "integer" },
        "entries_experimental": { "type": "integer" },
        "last_ingest_at": { "type": "string" }
      }
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/knowledge_entry" }
    },
    "regression_signals": {
      "type": "array",
      "items": { "$ref": "#/$defs/regression_signal" }
    },
    "compression_profile": {
      "type": "object",
      "properties": {
        "tier1_max_tokens": { "type": "integer", "default": 200 },
        "tier2_max_tokens": { "type": "integer", "default": 800 },
        "last_compressed_at": { "type": "string" }
      }
    }
  },
  "$defs": {
    "knowledge_entry": {
      "type": "object",
      "required": ["id", "kind", "status", "title", "source"],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "enum": ["pattern", "anti_pattern", "constraint", "checklist", "failure_mode", "success_recipe"]
        },
        "status": { "enum": ["experimental", "proven", "deprecated", "superseded"] },
        "title": { "type": "string", "maxLength": 120 },
        "body": { "type": "string" },
        "body_compressed": { "type": "string" },
        "source": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "enum": ["postmortem", "adr", "outcome", "execution", "verification", "manual"] },
            "venture_slug": { "type": "string" },
            "decision_id": { "type": "string" },
            "ref": { "type": "string" }
          }
        },
        "scope": {
          "type": "object",
          "properties": {
            "platforms": { "type": "array", "items": { "type": "string" } },
            "templates": { "type": "array", "items": { "type": "string" } }
          }
        },
        "evidence_refs": { "type": "array", "items": { "type": "string" } },
        "promoted_at": { "type": "string" },
        "superseded_by": { "type": "string" },
        "confidence": {
          "enum": ["single_venture", "multi_venture", "cross_platform"],
          "description": "Evidence breadth — not a trust score"
        },
        "tags": { "type": "array", "items": { "type": "string" } },
        "regression_watch": { "type": "boolean", "default": false }
      }
    },
    "regression_signal": {
      "type": "object",
      "required": ["detected_at", "entry_id", "signal"],
      "properties": {
        "detected_at": { "type": "string" },
        "entry_id": { "type": "string" },
        "signal": { "enum": ["proven_violated", "failure_recurrence", "verification_miss"] },
        "venture_slug": { "type": "string" },
        "decision_id": { "type": "string" },
        "detail": { "type": "string" }
      }
    }
  }
}
