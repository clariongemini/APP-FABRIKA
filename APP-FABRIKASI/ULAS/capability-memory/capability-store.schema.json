{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Capability Memory Store v2",
  "description": "Four layers per capability: knowledge, antipatterns, playbooks, benchmarks. Health is computed — not a trust score.",
  "type": "object",
  "required": ["capability_id", "schema_version", "knowledge", "antipatterns", "playbooks", "benchmarks"],
  "properties": {
    "capability_id": { "type": "string" },
    "label": { "type": "string" },
    "schema_version": { "const": "2.0" },
    "updated_at": { "type": "string" },
    "knowledge": { "$ref": "#/$defs/layer_knowledge" },
    "antipatterns": { "$ref": "#/$defs/layer_antipatterns" },
    "playbooks": { "$ref": "#/$defs/layer_playbooks" },
    "benchmarks": { "$ref": "#/$defs/layer_benchmarks" },
    "regression_signals": { "type": "array" },
    "compression_profile": { "type": "object" },
    "health": { "$ref": "#/$defs/capability_health" }
  },
  "$defs": {
    "source": {
      "type": "object",
      "properties": {
        "type": { "enum": ["outcome", "postmortem", "adr", "execution", "verification", "evidence", "manual"] },
        "venture_slug": { "type": "string" },
        "decision_id": { "type": "string" },
        "ref": { "type": "string" }
      }
    },
    "knowledge_entry": {
      "type": "object",
      "required": ["id", "status", "title"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "enum": ["pattern", "constraint", "success_recipe", "checklist"] },
        "status": { "enum": ["experimental", "proven", "deprecated", "superseded"] },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "body_compressed": { "type": "string" },
        "source": { "$ref": "#/$defs/source" },
        "evidence_refs": { "type": "array" },
        "tags": { "type": "array" },
        "usage_count": { "type": "integer", "minimum": 0 },
        "success_count": { "type": "integer", "minimum": 0 },
        "failure_count": { "type": "integer", "minimum": 0 },
        "last_used_at": { "type": ["string", "null"] },
        "last_impact": { "enum": ["success", "failure", null] }
      }
    },
    "antipattern_entry": {
      "type": "object",
      "required": ["id", "title", "status", "severity"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z]+\\.[a-z_]+\\.\\d{3}$" },
        "title": { "type": "string" },
        "status": { "enum": ["experimental", "proven", "deprecated"] },
        "severity": { "enum": ["low", "medium", "high", "critical"] },
        "body": { "type": "string" },
        "body_compressed": { "type": "string" },
        "evidence_count": { "type": "integer", "minimum": 0 },
        "source": { "$ref": "#/$defs/source" },
        "tags": { "type": "array" },
        "regression_watch": { "type": "boolean" },
        "usage_count": { "type": "integer", "minimum": 0 },
        "success_count": { "type": "integer", "minimum": 0 },
        "failure_count": { "type": "integer", "minimum": 0 },
        "last_used_at": { "type": ["string", "null"] },
        "last_impact": { "enum": ["success", "failure", null] }
      }
    },
    "playbook_entry": {
      "type": "object",
      "required": ["id", "title", "steps"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "enum": ["experimental", "proven", "deprecated"] },
        "steps": { "type": "array", "items": { "type": "string" } },
        "when_to_use": { "type": "string" },
        "source": { "$ref": "#/$defs/source" },
        "tags": { "type": "array" },
        "usage_count": { "type": "integer", "minimum": 0 },
        "success_count": { "type": "integer", "minimum": 0 },
        "failure_count": { "type": "integer", "minimum": 0 },
        "last_used_at": { "type": ["string", "null"] },
        "last_impact": { "enum": ["success", "failure", null] }
      }
    },
    "benchmark_entry": {
      "type": "object",
      "required": ["id", "project_type"],
      "properties": {
        "id": { "type": "string" },
        "project_type": { "type": "string" },
        "venture_slug": { "type": "string" },
        "metrics": { "type": "object", "additionalProperties": { "type": "number" } },
        "source": { "$ref": "#/$defs/source" },
        "recorded_at": { "type": "string" }
      }
    },
    "layer_knowledge": {
      "type": "object",
      "properties": { "entries": { "type": "array", "items": { "$ref": "#/$defs/knowledge_entry" } } }
    },
    "layer_antipatterns": {
      "type": "object",
      "properties": { "entries": { "type": "array", "items": { "$ref": "#/$defs/antipattern_entry" } } }
    },
    "layer_playbooks": {
      "type": "object",
      "properties": { "entries": { "type": "array", "items": { "$ref": "#/$defs/playbook_entry" } } }
    },
    "layer_benchmarks": {
      "type": "object",
      "properties": { "entries": { "type": "array", "items": { "$ref": "#/$defs/benchmark_entry" } } }
    },
    "capability_health": {
      "type": "object",
      "description": "Organizational memory quality — counts and trends, NOT trust/readiness score",
      "properties": {
        "computed_at": { "type": "string" },
        "proven_patterns": { "type": "integer" },
        "experimental_patterns": { "type": "integer" },
        "active_antipatterns": { "type": "integer" },
        "proven_antipatterns": { "type": "integer" },
        "playbook_count": { "type": "integer" },
        "benchmark_count": { "type": "integer" },
        "prevented_failures": { "type": "integer" },
        "last_regression": { "type": ["string", "null"] },
        "trend": { "enum": ["strengthening", "stable", "weakening", "sparse"] },
        "memory_quality": { "enum": ["sparse", "growing", "mature"] }
      }
    }
  }
}
