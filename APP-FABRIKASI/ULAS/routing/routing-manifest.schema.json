{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ULAS Capability Routing Manifest",
  "description": "Output of Capability Router — binds work packages to capability IDs and providers.",
  "type": "object",
  "required": ["routing_id", "decision_id", "capabilities_needed", "bindings"],
  "properties": {
    "routing_id": { "type": "string" },
    "decision_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "policy_version": { "type": "string" },
    "policy_source": { "type": "string" },
    "capabilities_needed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["work_package_id", "capability_id", "provider_id"],
        "properties": {
          "work_package_id": { "type": "string" },
          "capability_id": { "type": "string" },
          "label": { "type": "string" },
          "role": { "type": "string" },
          "platform": { "type": "string" },
          "provider_id": { "type": "string" },
          "provider_type": { "type": "string" },
          "dispatch": { "enum": ["manual", "automated", "delegated"] },
          "wired": { "type": "boolean" }
        }
      }
    }
  }
}
