{
  "version": "1.0",
  "description": "Executable backends. Swap providers without changing capabilities or work chains.",
  "providers": {
    "human": {
      "label": "Human",
      "type": "manual",
      "dispatch": "manual",
      "wired": true
    },
    "local_shell": {
      "label": "Local Shell",
      "type": "local_shell",
      "dispatch": "automated",
      "wired": true
    },
    "cursor": {
      "label": "Cursor",
      "type": "ai_ide",
      "dispatch": "delegated",
      "wired": true,
      "adapter": "adapters/cursor_dispatch.py",
      "adapter_mode": "ide_queue",
      "sdk_mode": "optional",
      "fallback_mode": "queue",
      "requires_env": ["CURSOR_API_KEY"],
      "invoke_schema": "ai_invoke"
    },
    "claude": {
      "label": "Claude",
      "type": "ai_api",
      "dispatch": "delegated",
      "wired": false,
      "invoke_schema": "ai_invoke"
    },
    "gemini": {
      "label": "Gemini",
      "type": "ai_api",
      "dispatch": "delegated",
      "wired": false,
      "invoke_schema": "ai_invoke"
    },
    "openai": {
      "label": "OpenAI",
      "type": "ai_api",
      "dispatch": "delegated",
      "wired": false,
      "invoke_schema": "ai_invoke"
    }
  }
}
