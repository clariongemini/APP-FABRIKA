{
  "version": "2.0",
  "name": "decision_lifecycle",
  "states": [
    "TASK_RECEIVED",
    "CONTEXT_ASSEMBLY",
    "READ_MORE_REQUIRED",
    "CONTEXT_COMPLETE",
    "CLASSIFIED",
    "CONFIDENCE_SCORED",
    "REVIEW_CHAIN",
    "APPROVAL",
    "EXECUTION",
    "AUDIT",
    "MEMORY_UPDATE",
    "CLOSED"
  ],
  "transitions": [
    {"from": "TASK_RECEIVED", "to": "CONTEXT_ASSEMBLY", "action": "assemble_context"},
    {"from": "CONTEXT_ASSEMBLY", "to": "READ_MORE_REQUIRED", "guard": "missing_required_reads"},
    {"from": "CONTEXT_ASSEMBLY", "to": "CONTEXT_COMPLETE", "guard": "all_reads_complete"},
    {"from": "READ_MORE_REQUIRED", "to": "CONTEXT_COMPLETE", "action": "complete_reads"},
    {"from": "CONTEXT_COMPLETE", "to": "CLASSIFIED", "action": "classify_decision"},
    {"from": "CLASSIFIED", "to": "CONFIDENCE_SCORED", "action": "score_confidence"},
    {"from": "CONFIDENCE_SCORED", "to": "REVIEW_CHAIN", "guard": "confidence_allows"},
    {"from": "CONFIDENCE_SCORED", "to": "READ_MORE_REQUIRED", "guard": "confidence_blocked"},
    {"from": "REVIEW_CHAIN", "to": "APPROVAL", "guard": "review_chain_satisfied"},
    {"from": "APPROVAL", "to": "EXECUTION", "guard": "approved"},
    {"from": "EXECUTION", "to": "AUDIT", "action": "record_audit"},
    {"from": "AUDIT", "to": "MEMORY_UPDATE", "action": "update_memory"},
    {"from": "MEMORY_UPDATE", "to": "CLOSED", "action": "close"}
  ],
  "blocked_terminal": ["BLOCKED_LOW_CONFIDENCE", "BLOCKED_NEVER_AGAIN", "BLOCKED_REVIEW_CHAIN"]
}
