{
  "version": "1.0",
  "description": "Canonical capability catalog — metadata, verification, evidence, default provider.",
  "capabilities": {
    "android.architecture": {
      "label": "Android Architecture",
      "platform": "android",
      "role": "architect",
      "execution_class": "implementation",
      "verification_requirements": ["module_boundary_check", "build_success"],
      "evidence_requirements": ["build.status=success", "architecture_notes"],
      "default_provider": "cursor"
    },
