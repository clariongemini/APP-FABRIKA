    "architect": { "android": "android.architecture", "web": "web.architecture", "ios": "ios.architecture", "backend": "backend.architecture", "ai": "ai.reasoning", "*": "generic.architecture" },
    "security": { "android": "android.security", "backend": "backend.security", "*": "android.security" },
