{
  "version": "2.0",
  "description": "Calibration not punishment. Trust 0-100 per capability.",
  "initial_trust": 85,
  "capabilities": {
    "planner": {"trust": 85, "reviews": 0, "calibration_delta": 0},
    "architect": {"trust": 92, "reviews": 0, "calibration_delta": 0},
    "security": {"trust": 95, "reviews": 0, "calibration_delta": 0},
    "qa": {"trust": 88, "reviews": 0, "calibration_delta": 0},
    "performance": {"trust": 85, "reviews": 0, "calibration_delta": 0},
    "ux": {"trust": 85, "reviews": 0, "calibration_delta": 0},
    "auditor": {"trust": 90, "reviews": 0, "calibration_delta": 0}
  },
  "calibration": {
    "good_outcome_delta": 0.5,
    "missed_risk_delta": -1.0,
    "floor": 50,
    "ceiling": 100,
    "note": "Learn, do not block reviewers below floor automatically"
  },
  "weighted_review": {
    "enabled": true,
    "formula": "effective_approval = reviewer_trust / 100"
  }
}
