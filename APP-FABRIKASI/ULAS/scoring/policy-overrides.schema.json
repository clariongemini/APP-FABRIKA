{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ULAS Runtime Policy Overrides",
  "description": "Learned adaptations — merged at decide() time. Canonical policies unchanged.",
  "type": "object",
  "properties": {
    "version": { "type": "string" },
    "review_matrix": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "additional_required": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "decision_classes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "min_reviews_delta": { "type": "integer" },
          "tier_floor": { "oneOf": [{ "type": "integer" }, { "const": "critical" }] }
        }
      }
    },
    "confidence_weight_deltas": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "changelog": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "at": { "type": "string" },
          "decision_id": { "type": "string" },
          "adaptation": { "type": "object" }
        }
      }
    }
  }
}
