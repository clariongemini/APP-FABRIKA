{
  "version": "1.0",
  "description": "Predictive risk — observation before decision. No new agents.",
  "status": "designed",
  "activation_gate": {
    "enabled": false,
    "auto_enable_when": {
      "min_decisions": 20,
      "min_outcomes_evaluated": 10,
      "min_readiness_snapshots": 4,
      "min_evidence_bundles": 1,
      "min_shipped_ventures": 1
    },
    "note": "Escalation enforced only when gate active. Preview always via: ulas risk"
  },
  "class_base": {
    "A": 12,
    "B": 32,
    "C": 52,
    "D": 72
  },
  "factor_weights": {
    "reviewer_trust": 0.22,
    "reviewer_history": 0.18,
    "context_tier": 0.10,
    "evidence_level": 0.18,
    "memory_hits": 0.12,
    "policy_overrides": 0.05,
    "complexity": 0.10,
    "similar_failures": 0.05
  },
  "bands": {
    "low": { "min": 0, "max": 39, "label": "low" },
    "medium": { "min": 40, "max": 59, "label": "medium" },
    "high": { "min": 60, "max": 79, "label": "high" },
    "critical": { "min": 80, "max": 100, "label": "critical" }
  },
  "escalation": {
    "low": { "action": "standard" },
    "medium": {
      "action": "extra_reviewer",
      "additional_capabilities": ["auditor"]
    },
    "high": {
      "action": "auditor_required",
      "required_capabilities": ["auditor"]
    },
    "critical": {
      "action": "founder_gate",
      "required_capabilities": ["auditor", "security"],
      "founder_approval": true
    }
  },
  "evidence_risk": {
    "none": 1.0,
    "partial": 0.45,
    "collected": 0.0
  },
  "tier_risk": {
    "1": 0.0,
    "2": 0.25,
    "3": 0.55,
    "critical": 0.85
  }
}
