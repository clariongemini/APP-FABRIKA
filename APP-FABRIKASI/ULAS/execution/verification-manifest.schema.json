{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ULAS Verification Manifest",
  "description": "Proof checks + repair loop policy.",
  "type": "object",
  "required": ["checks"],
  "properties": {
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "expect"],
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["gradle", "script", "file_exists", "json_field"] },
          "task": { "type": "string" },
          "cmd": { "type": "string" },
          "path": { "type": "string" },
          "field": { "type": "string" },
          "expect": {},
          "optional": { "type": "boolean", "default": false },
          "provider": { "enum": ["local_shell"], "default": "local_shell" }
        }
      }
    },
    "retry_policy": {
      "type": "object",
      "properties": {
        "max_attempts": { "type": "integer", "default": 3 },
        "on_fail": { "type": "string" },
        "repair_capability": { "type": "string", "default": "architect" }
      }
    }
  }
}
