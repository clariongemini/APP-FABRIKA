{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ULAS Execution Manifest",
  "description": "Commands to run after work generate. Provider: local_shell.",
  "type": "object",
  "required": ["codebase_path", "platform", "commands"],
  "properties": {
    "codebase_path": { "type": "string" },
    "codebase_resolved": { "type": "string" },
    "platform": { "type": "string" },
    "bridge": { "type": "string" },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "cmd"],
        "properties": {
          "id": { "type": "string" },
          "cwd": { "type": "string" },
          "cmd": { "type": "string" },
          "provider": { "enum": ["local_shell", "human"], "default": "local_shell" },
          "capability": { "type": "string" },
          "timeout_sec": { "type": "integer", "default": 600 }
        }
      }
    }
  }
}
