{
  "schema": "factory.context.manifest.v1",
  "version": "1.0.0",
  "description": "Session bootstrap reading order — context engineering, not governance expansion",
  "session_start": [
    {
      "path": "YAPILACAKLAR.md",
      "required": true,
      "purpose": "Active phase and next task"
    },
    {
      "path": "docs/00-INDEX.md",
      "required": true,
      "purpose": "Project memory index"
    },
    {
      "path": ".factory/context/LAST_DECISION.md",
      "required": false,
      "purpose": "Most recent architectural or product decision"
    },
    {
      "path": "docs/TODO.md",
      "required": false,
      "purpose": "Factory or project backlog sync"
    },
    {
      "path": "docs/02-ARCHITECTURE/ANDROID_STRUCTURE.md",
      "required": false,
      "purpose": "Module layout reference"
    },
    {
      "path": "docs/FACTORY_META/PRODUCT_BRIEF.md",
      "required": false,
      "purpose": "Vision and scope (per-project after init)"
    },
    {
      "path": "governance/product_decision/roadmap_priorities.json",
      "required": false,
      "purpose": "PDC roadmap priorities (runtime or governance)"
    }
  ],
  "phase_overrides": {
    "F0": ["docs/EXECUTIVE_OS.md", "docs/MCP_SETUP.md"],
    "F1": ["docs/01-VISION/", "docs/FACTORY_META/"],
    "F2": ["docs/02-ARCHITECTURE/", "docs/33-LAYER-MANIFEST/README.md"],
    "F3": ["docs/33-LAYER-MANIFEST/layer-03.yaml", "docs/33-LAYER-MANIFEST/layer-04.yaml"],
    "F4": ["docs/03-STANDARDS/LIQUID_GLASS.md", "docs/03-STANDARDS/I18N.md"],
    "F5": ["docs/03-STANDARDS/SECURITY.md", "docs/03-STANDARDS/OEM_COMPATIBILITY.md"],
    "F6": ["governance/analytics/", "docs/03-STANDARDS/PERFORMANCE.md"],
    "F7": ["governance/executive/APPROVAL_QUEUE.md"],
    "F8": ["docs/RELEASE_CHECKLIST.md", "docs/CHANGELOG.md"]
  },
  "knowledge_hooks": [
    "docs/LEARNING_FACTORY.md",
    "knowledge/patterns/README.md",
    "knowledge/patterns/proven/README.md",
    "knowledge/postmortems/README.md",
    "knowledge/ventures/README.md",
    "knowledge/failures/README.md",
    "knowledge/outcomes/README.md",
    "knowledge/adr/ADR-LIFECYCLE.md"
  ],
  "runtime_queries": [
    {
      "script": "./scripts/factory/query-memory.sh",
      "when": "Before repeating a fix or architecture choice",
      "example": "./scripts/factory/query-memory.sh navigation --graph"
    },
    {
      "script": "python3 scripts/factory/intelligence-engine.py",
      "when": "New venture or app — ask portfolio insights",
      "example": "python3 scripts/factory/intelligence-engine.py --ask retention-by-pattern --last 10"
    },
    {
      "script": "python3 scripts/factory/analyze-outcomes.py",
      "when": "Pattern recommendations from outcomes",
      "example": "python3 scripts/factory/analyze-outcomes.py --top 3"
    }
  ]
}
